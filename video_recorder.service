[Unit]
Description=Wedding Phone Video Recorder
After=network.target audioGuestBook.service
Wants=audioGuestBook.service

[Service]
ExecStart=/usr/bin/python3 /home/admin/time-capsule-cam/video_recorder.py
WorkingDirectory=/home/admin
StandardOutput=journal
StandardError=journal
Restart=always
RestartSec=5
User=admin

[Install]
WantedBy=multi-user.target
